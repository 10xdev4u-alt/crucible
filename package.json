{
  "name": "crucible",
  "version": "0.0.0",
  "private": true,
  "description": "Multi-agent code review orchestrator",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm --filter @crucible/core run build && pnpm --filter @crucible/cli run build",
    "build:docs": "pnpm --filter @crucible/docs-site run build",
    "test": "pnpm -r run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm --filter @crucible/core run build && pnpm -r run typecheck",
    "clean": "pnpm -r exec rm -rf dist node_modules .tsbuildinfo"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^22.10.5",
    "esbuild": "^0.28.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
